<Window
    x:Class="Dictator.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Dictator"
    xmlns:tb="using:H.NotifyIcon"
    Title="Диктатор">

    <Grid x:Name="RootGrid" RequestedTheme="Dark" Background="#121212">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tray icon (must be in visual tree for Loaded to fire) -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="Диктатор"
                        ContextMenuMode="SecondWindow"
                        NoLeftClickDelay="True"/>

        <!-- Custom title bar (SetTitleBar handles drag natively) -->
        <Grid x:Name="TitleBar" Grid.Row="0" Background="#191919">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="10,0,0,0"
                        IsHitTestVisible="False">
                <Image Source="Assets/icon.png" Width="18" Height="18" Margin="0,0,8,0"/>
                <TextBlock Text="Dictator"
                           Foreground="#C8C8C8"
                           FontSize="13"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Button x:Name="BtnSettings"
                    Grid.Column="1"
                    Width="40" Height="44"
                    Click="BtnSettings_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    ToolTipService.ToolTip="Настройки">
                <FontIcon Glyph="&#xE713;" FontSize="14" Foreground="#969696"/>
            </Button>

            <Button x:Name="BtnClose"
                    Grid.Column="2"
                    Width="46" Height="44"
                    Click="BtnClose_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    ToolTipService.ToolTip="Свернуть в трей">
                <FontIcon Glyph="&#xE8BB;" FontSize="11" Foreground="#969696"/>
            </Button>
        </Grid>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
            </Grid.RowDefinitions>

            <!-- Mic button (code-only control, cursor set in MicButton constructor) -->
            <local:MicButton x:Name="BtnMic"
                             Grid.Row="0"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Tapped="BtnMic_Tapped"/>

            <!-- Status label -->
            <TextBlock x:Name="LblStatus"
                       Grid.Row="1"
                       Text="Нажмите для записи"
                       HorizontalAlignment="Center"
                       Foreground="#8C8C8C"
                       FontSize="11"
                       Margin="20,8,20,12"/>

            <!-- Separator -->
            <Rectangle Grid.Row="2" Fill="#2D2D2D" Margin="20,0"/>

            <!-- Result row -->
            <Grid Grid.Row="3" Margin="20,12,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtResult"
                         Grid.Column="0"
                         PlaceholderText="Распознанный текст появится здесь..."
                         IsReadOnly="True"
                         Background="#232323"
                         Foreground="White"
                         BorderThickness="0"
                         FontSize="12"
                         MinHeight="60"
                         MaxHeight="120"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                <StackPanel Grid.Column="1" Spacing="4" Margin="8,0,0,0" VerticalAlignment="Top">
                    <Button x:Name="BtnCopy"
                            Width="36" Height="32"
                            Click="BtnCopy_Click"
                            Visibility="Collapsed"
                            Background="#323232"
                            ToolTipService.ToolTip="Копировать">
                        <FontIcon Glyph="&#xE8C8;" FontSize="13" Foreground="#CCCCCC"/>
                    </Button>
                    <Button x:Name="BtnHistory"
                            Width="36" Height="32"
                            Click="BtnHistory_Click"
                            Background="#323232"
                            ToolTipService.ToolTip="История">
                        <FontIcon Glyph="&#xE81C;" FontSize="13" Foreground="#CCCCCC"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Hint -->
            <TextBlock x:Name="LblHint"
                       Grid.Row="4"
                       Text="Текст скопируется автоматически"
                       HorizontalAlignment="Center"
                       Foreground="#505050"
                       FontSize="10"
                       Margin="20,8,20,0"/>
        </Grid>
    </Grid>
</Window>
